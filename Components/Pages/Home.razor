@page "/"
@inject ProductService productService
@inject NavigationManager nav
@using ECommerceBlazorApp.Models
@using ECommerceBlazorApp.Services

<!-- ================= HERO SECTION ================= -->
<section class="hero">
    <div class="hero-content text-center">
        <h1 class="fw-bold">
            <i class="bi bi-shop"></i> Welcome to Our Store
        </h1>
        <p class="text">
            <i class="bi bi-stars"></i> Best products at best prices
        </p>
    </div>
</section>

<!-- ================= PRODUCTS ================= -->
<section id="products" class="container mt-5">

    <div class="text-center mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-grid"></i> Our Products
        </h2>
        <p class="text-muted">Carefully selected just for you</p>
    </div>

    <div class="row">
        @foreach (var product in products)
        {
            <div class="col-md-4 d-flex">
                <div class="card shadow-sm m-2 w-100 product-card">

                    <img src="@product.ImageUrl" class="card-img-top product-img" />

                    <div class="card-body text-center">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-success fw-bold">Rs. @product.Price</p>

                        <button class="btn btn-dark w-100"
                                @onclick="() => OrderNow(product.Id)">
                            <i class="bi bi-cart-plus"></i> Order Now
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>

</section>

<!-- ================= REVIEWS ================= -->
<section class="reviews mt-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-4">
            <i class="bi bi-chat-dots"></i> Customer Reviews
        </h2>

        <div class="review">
            <p>"Amazing quality and fast delivery!"</p>
            <span><i class="bi bi-person"></i> Usman Hamza</span>
        </div>

        <div class="review">
            <p>"Very satisfied with the service."</p>
            <span><i class="bi bi-person"></i> Inaya Abdal</span>
        </div>
    </div>
</section>

<!-- ================= FOOTER ================= -->
<footer class="footer mt-5">
    <p>
        <i class="bi bi-c-circle"></i> 2026 Your Store |
        <i class="bi bi-shield-check"></i> All Rights Reserved
    </p>
</footer>

@code {
    List<Product> products;

    protected override void OnInitialized()
    {
        products = productService.GetProducts();
    }

    void OrderNow(int id)
    {
        nav.NavigateTo($"/orderform/{id}");
    }
}