@page "/orderconfirmed"
@inject OrderService orderService
@inject NavigationManager nav
@using ECommerceBlazorApp.Models
@using ECommerceBlazorApp.Services
<div class="container mt-4">
    <div class="card p-4 shadow text-center">

        @if (order == null)
        {
            <h4 class="text-warning">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> No recent order found
            </h4>
            <p>Please place an order first using the "Order Now" button on the home page.</p>
            <button class="btn btn-primary mt-3" @onclick="GoHome">
                <i class="bi bi-house-door me-1"></i> Back to Home
            </button>
        }
        else
        {
            <h2 class="text-success">
                <i class="bi bi-check-circle-fill me-2"></i> Order Confirmed!
            </h2>

            <p>
                <i class="bi bi-box-seam me-1 text-primary"></i>
                <b>Product:</b> @order.SelectedProduct?.Name
            </p>

            <p>
                <i class="bi bi-123 me-1 text-dark"></i>
                <b>Quantity:</b> @order.Quantity
            </p>

            <p>
                <i class="bi bi-cash-coin me-1 text-success"></i>
                <b>Total:</b> Rs. @order.TotalPrice
            </p>

            <h4 class="mt-3">
                <i class="bi bi-heart-fill text-danger me-1"></i>
                Thank you for your order!
            </h4>

            <button class="btn btn-primary mt-3" @onclick="GoHome">
                <i class="bi bi-house-door me-1"></i> Back to Home
            </button>
        }

    </div>
</div>

@code {
    Order order;

    protected override void OnInitialized()
    {
        order = orderService.GetLastOrder();
    }

    void GoHome()
    {
        nav.NavigateTo("/");
    }
}